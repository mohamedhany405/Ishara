# ──────────────────────────────────────────────────────────────────────────
#  Ishara Server – Environment Variables
#
#  SETUP INSTRUCTIONS:
#  1. Copy this file to .env  (or rename it)
#  2. Fill in your real values below
#  3. Never commit .env to git — it is in .gitignore
# ──────────────────────────────────────────────────────────────────────────

# MongoDB connection string (Atlas or local)
CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Gmail SMTP — use an App Password, NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Server
NODE_ENV=development
PORT=3000
