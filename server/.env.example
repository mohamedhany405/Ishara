# Runtime
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# MongoDB Atlas (preferred)
MONGODB_URI=mongodb+srv://ishara_app:YOUR_DB_PASSWORD@<cluster>.mongodb.net/ishara?retryWrites=true&w=majority&appName=Cluster0
# Backward-compatibility alias (optional)
# CONNECTION_STRING=${MONGODB_URI}

# Optional pattern: keep <db_password> in URI and inject from DB_PASSWORD
# MONGODB_URI=mongodb+srv://ishara_app:<db_password>@<cluster>.mongodb.net/ishara?retryWrites=true&w=majority&appName=Cluster0
# DB_PASSWORD=YOUR_DB_PASSWORD

# Frontend origins
CLIENT_ORIGIN=https://ishara-6ce5t0b1o-mohamedhany405s-projects.vercel.app
DEV_CLIENT_ORIGIN=http://localhost:3000
# Optional additional origins, comma separated
ALLOWED_ORIGINS=

# Public URLs used in emails and absolute file links
FRONTEND_URL=https://ishara-6ce5t0b1o-mohamedhany405s-projects.vercel.app
BACKEND_PUBLIC_URL=https://your-backend-project.vercel.app

# Auth
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=2d
SKIP_EMAIL_VERIFY=false

# Gmail SMTP for OTP and contact notifications
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password

# Cloudinary (production-safe avatar storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=ishara/avatars
